*/

SELECT
    window_start::TIMESTAMP_NTZ                              AS window_start,
    window_end::TIMESTAMP_NTZ                                AS window_end,
    ROUND(gps_lat_bucket::DOUBLE, 2)                         AS gps_lat_bucket,
